# renv — ignorar tudo exceto os arquivos necessários para CI
renv/*
!renv/activate.R
!renv/settings.json
!renv/.gitignore

# Quarto build output
_site/
_site_libs/
.quarto/

# Quarto freeze cache
_freeze/

# Cache and temporary files
*.log
*.tmp
*.aux
*.out
*.toc
*.bak
.ipynb_checkpoints/

# System files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo

# R session files
.Rhistory
.RData
.Rproj.user

# Render temporaries
render.log
render.out

# Materiais de referencia da UC
_originals/

# Configuracao do projeto
CLAUDE.md
WORKFLOW.md
.claude/

/.quarto/

# Estrutura de pastas
.tree.txt

# old files
_quarto-OLD-copy.yml
