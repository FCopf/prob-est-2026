*.bak
.ipynb_checkpoints/

# System files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo

# R session files
.Rhistory
.RData
.Rproj.user

# Render temporaries
render.log
render.out

