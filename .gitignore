# renv — ignorar tudo exceto os arquivos necessários para CI
renv/*
!renv/activate.R
!renv/settings.json
!renv/.gitignore

# Quarto build output
_site/
_site_libs/
.quarto/
.quarto-cache/

# Quarto freeze cache
_freeze/

